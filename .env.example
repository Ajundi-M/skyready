# Copy this file to .env.local and fill in your own values
# Never commit .env.local

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_key

# The canonical public URL of your deployment (no trailing slash).
# Used to build email confirmation links.
# Defaults to http://localhost:3000 when not set.
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com